                            <tr><td>2050</td><td>0,81</td><td>1,01</td><td>1,03</td><td>0,99</td><td>1,00</td><td>1,04</td><td>0,71</td><td>0,78</td></tr>
                            <tr><td>2060</td><td>0,76</td><td>1,02</td><td>1,02</td><td>0,98</td><td>1,01</td><td>1,05</td><td>0,68</td><td>0,75</td></tr>
                            <tr><td>2070</td><td>0,72</td><td>1,02</td><td>1,01</td><td>0,98</td><td>1,00</td><td>1,05</td><td>0,65</td><td>0,73</td></tr>
