            <h3>Annexe 4 : Code R complet des simulations</h3>
            <div class="formula-container" style="font-size:0.85em; line-height:1.3;">
                <div class="formula">
# ============================================================
# Simulation des MAA - Régime DB par répartition
# ============================================================

library(demography)
library(forecast)
library(ggplot2)

# === Paramètres du modèle ===
T_MAX <- 100          # Horizon de simulation
AGE_DEPART <- 20      # Âge d'entrée
AGE_RETRAITE <- 65    # Âge initial
TAUX_COTIS <- 0.16    # Taux initial
TAUX_REMPL <- 0.60    # Taux de remplacement
CROISS_SAL <- 0.01    # Croissance réelle des salaires

# === Chargement données ===
data_belgium <- read.demogdata("belgium.txt", "belgium_exp.txt")
lc_model <- lca(data_belgium, adjust = "dt", model = "poisson")

# === Projection espérance de vie ===
kt_forecast <- forecast(auto.arima(lc_model$kt), h = T_MAX)
e_65_projection <- life.expectancy(lc_model, kt = kt_forecast$mean, age = 65)

# === Initialisation ===
COTISANTS <- numeric(T_MAX)
RETRAITES <- numeric(T_MAX)
RSV <- matrix(NA, nrow = T_MAX, ncol = 6)
colnames(RSV) <- c("Sans_MAA", "MAA1", "MAA2", "MAA3", "MAA5", "Musgrave")

# Population initiale (2023)
COTISANTS[1] <- 5.2e6   # 5,2 millions d'actifs
RETRAITES[1] <- 2.08e6  # 2,08 millions de retraités

# === Boucle de simulation ===
for(t in 2:T_MAX) {
  # Mise à jour population
  NAISSES <- 1.6 * 250000 * (1 - 0.003)  # TFT * femmes fertiles
  DECES_ACTIFS <- COTISANTS[t-1] * 0.002
  COTISANTS[t] <- COTISANTS[t-1] + NAISSES - DECES_ACTIFS
  
  DECES_RETRAITES <- RETRAITES[t-1] * 0.035
  RETRAITES[t] <- RETRAITES[t-1] + (COTISANTS[t-AGE_RETRAITE+1] - COTISANTS[t-AGE_RETRAITE]) - DECES_RETRAITES
  
  # Ratio dépendance
  D_t <- RETRAITES[t] / COTISANTS[t]
  
  # === Application des MAA ===
  
  # MAA 1 : Cotisations
  if(t > 1) {
    d_cot <- (D_t / D_{t-1} * e_65_projection[t] / e_65_projection[t-1])^0.5
    taux_cotis_MAA1 <- min(0.25, taux_cotis_MAA1 * d_cot)
  }
  
  # MAA 2 : Âge de retraite
  ratio_cible <- e_65_projection[t-1] / (AGE_RETRAITE - AGE_DEPART)
  ratio_actuel <- e_65_projection[t] / (AGE_RETRAITE + 0.3 - AGE_DEPART)
  if(ratio_actuel < ratio_cible & AGE_RETRAITE < 70) {
    AGE_RETRAITE_MAA2 <- AGE_RETRAITE_MAA2 + 0.3
  }
  
  # MAA 3 : Âge + amélioration pension
  pension_MAA3 <- pension_MAA3 * 1.005 * (D_{t-1} / D_t)^0.2
  
  # MAA 5 : Facteur durabilité
  facteur_durab <- facteur_durab * (D_{t-1} * e_65_projection[t-1]) / (D_t * e_65_projection[t])
  pension_MAA5 <- pension_initiale * facteur_durab
  
  # Musgrave
  ratio_musgrave <- pension_musgrave / (salaire_moyen * (1 - taux_cotis_musgrave))
  if(ratio_musgrave > 0.45) {
    taux_cotis_musgrave <- taux_cotis_musgrave + 0.5 * (ratio_musgrave - 0.45)
    pension_musgrave <- pension_musgrave - 0.5 * (ratio_musgrave - 0.45) * salaire_moyen
  }
  
  # === Calcul RSV ===
  salaire_moyen <- salaire_moyen * (1 + CROISS_SAL)
  cotisations <- COTISANTS[t] * salaire_moyen * taux_cotis_variant
  prestations <- RETRAITES[t] * pension_variant
  RSV[t, variant] <- cotisations / prestations
}

# === Visualisation ===
ggplot(data.frame(annee = 2023:(2023+T_MAX-1), RSV = RSV)) +
  geom_line(aes(x = annee, y = RSV, color = variable), size = 1) +
  geom_hline(yintercept = 1, linetype = "dashed", color = "red") +
  labs(title = "Ratio de solvabilité par mécanisme",
       subtitle = "Scénario central 2023-2123")
                </div>
            </div>

            <h3>Annexe 5 : Sources de données</h3>
            <ul>
                <li><strong>Mortalité :</strong> Human Mortality Database (HMD), www.mortality.org, Belgique, période 1981-2023</li>
                <li><strong>Démographie :</strong> Statbel (Institut belge de statistique), projections 2023-2070</li>
                <li><strong>Salaires :</strong> Enquête Structure des Salaires (Eurostat), SSIF (UTE), 2015-2023</li>
                <li><li><strong>Paramètres économiques :</strong> FMI (World Economic Outlook), Conseil supérieur des Finances (2023)</li>
                <li><strong>Logiciels :</strong> R version 4.3.1, packages : demography 1.22, forecast 8.21, StMoMo 0.45</li>
            </ul>

            <h3>Annexe 6 : Glossaire des acronymes</h3>
            <div class="grid-2">
                <div>
                    <ul>
                        <li><strong>AIC</strong> : Akaike Information Criterion</li>
                        <li><strong>BIC</strong> : Bayesian Information Criterion</li>
                        <li><strong>DB</strong> : Prestations Définies (Defined Benefit)</li>
                        <li><strong>DC</strong> : Cotisations Définies (Defined Contribution)</li>
                        <li><strong>DR</strong> : Ratio de Dépendance (Dependency Ratio)</li>
                        <li><strong>MAA</strong> : Mécanisme d'Ajustement Automatique</li>
                        <li><strong>MAPE</strong> : Mean Absolute Percentage Error</li>
                    </ul>
                </div>
                <div>
                    <ul>
                        <li><strong>MLE</strong> : Maximum Likelihood Estimation</li>
                        <li><strong>NDC</strong> : Non-Financial Defined Contribution</li>
                        <li><strong>RSV</strong> : Ratio de Solvabilité (solvency ratio)</li>
                        <li><strong>SVD</strong> : Singular Value Decomposition</li>
                        <li><strong>SMR</strong> : Standardized Mortality Ratio</li>
                        <li><strong>TFT</strong> : Taux de Fécondité Totale</li>
                    </ul>
                </div>
            </div>
        </section>

