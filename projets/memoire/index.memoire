<base target="_blank">
</head>
<body>
    <div class="container">
        <!-- HEADER -->
        <header class="header">
            <h1>Ajustement des pensions de sécurité sociale à l'espérance de vie</h1>
            <p class="subtitle">Mémoire de Master 120 en Sciences Actuarielles</p>
            <div class="meta">
                <div class="meta-item">
                    <span class="meta-label">Auteur :</span>
                    <span>SIMO TCHEMO Steve Géraldin</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Promoteur :</span>
                    <span>Prof. Pierre Devolder</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Lecteur :</span>
                    <span>Prof. Pierre Ars</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Institution :</span>
                    <span>UCLouvain - ISBA</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Année académique :</span>
                    <span>2023-2024</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Date de soutenance :</span>
                    <span>Septembre 2024</span>
                </div>
            </div>
        </header>

        <!-- NAVIGATION -->
        <nav class="nav-container">
            <div class="nav-main">
                <ul class="nav-list">
                    <li><a href="#introduction">📖 Introduction</a></li>
                    <li><a href="#chapitre1">1️⃣ Fondements</a></li>
                    <li><a href="#chapitre2">2️⃣ MAA</a></li>
                    <li><a href="#chapitre3">3️⃣ Modèles</a></li>
                    <li><a href="#chapitre4">4️⃣ Application</a></li>
                    <li><a href="#conclusion">🏆 Conclusion</a></li>
                    <li><a href="#annexes">📎 Annexes</a></li>
                    <li><a href="#bibliographie">📚 Bibliographie</a></li>
                </ul>
            </div>
        </nav>

        <!-- SOMMAIRE -->
        <section id="sommaire" class="section">
            <h2>📋 Sommaire du mémoire</h2>
            <div class="grid-2">
                <div>
                    <h3>Partie I : Théorie et contexte</h3>
                    <ul>
                        <li><strong>Chapitre 1</strong> : Fondements des systèmes de pension et défi démographique
                            <ul>
                                <li>Les trois piliers de la retraite</li>
                                <li>Méthodes de financement (DB vs DC)</li>
                                <li>Impact du vieillissement démographique</li>
                                <li>Équilibre actuariel et ratio de dépendance</li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3>Partie II : Mécanismes d'ajustement</h3>
                    <ul>
                        <li><strong>Chapitre 2</strong> : Théorie des MAA
                            <ul>
                                <li>Définition et classification</li>
                                <li>Systèmes suédois et néerlandais</li>
                                <li>Modélisation de l'équité intergénérationnelle</li>
                                <li>Les 5 MAA d'Ayuso & Bravo</li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="grid-2">
                <div>
                    <h3>Partie III : Modélisation stochastique</h3>
                    <ul>
                        <li><strong>Chapitre 3</strong> : Modèles de longévité
                            <ul>
                                <li>Estimateurs de mortalité (Hoem)</li>
                                <li>Modèle de Lee-Carter (1992)</li>
                                <li>Modèle Log-Poisson (Brouhns et al.)</li>
                                <li>Critères de sélection et projection</li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3>Partie IV : Application empirique</h3>
                    <ul>
                        <li><strong>Chapitre 4</strong> : Simulations et stress tests
                            <ul>
                                <li>Méthodologie de simulation</li>
                                <li>Application des 5 MAA</li>
                                <li>Scénarios de stress démographiques</li>
                                <li>Analyse comparée et règle de Musgrave</li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="grid-2">
                <div>
                    <h3>Partie V : Conclusion</h3>
                    <ul>
                        <li><strong>Chapitre 5</strong> : Synthèse et recommandations
                            <ul>
                                <li>Performance des MAA</li>
                                <li>Recommandations politiques</li>
                                <li>Limites et perspectives de recherche</li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3>Annexes</h3>
                    <ul>
                        <li><strong>Annexe 1</strong> : Méthode ARIMA et code R</li>
                        <li><strong>Annexe 2</strong> : Structures de population</li>
                        <li><strong>Annexe 3</strong> : Ratios de solvabilité détaillés</li>
                        <li><strong>Annexe 4</strong> : Bibliographie sélective</li>
                    </ul>
                </div>
            </div>

            <div class="concept-box">
                <div class="concept-title">Mot-clés</div>
                <p>Systèmes de pension, vieillissement démographique, mécanismes d'ajustement automatique, équité intergénérationnelle, modèle de Lee-Carter, modèle Log-Poisson, stress tests, règle de Musgrave, solvabilité actuarielle.</p>
            </div>
        </section>

        <!-- INTRODUCTION -->
        <section id="introduction" class="section">
            <h2>📖 Introduction générale</h2>

            <div class="concept-box">
                <div class="concept-title">Contexte du problème</div>
                <p>La Belgique, comme la plupart des pays développés, fait face à une <strong>double transition démographique</strong> sans précédent : l'allongement massif de l'espérance de vie conjugué à une chute durable de la fécondité. En 2023, l'espérance de vie à la naissance atteint 81,6 ans pour les hommes et 85,2 ans pour les femmes, soit +4 ans en 40 ans. Parallèlement, le taux de natalité est tombé à 1,6 enfant par femme, bien sous le seuil de renouvellement génétique (2,1).</p>
                <p>Ce choc démographique met à mal le <strong>contrat social du système par répartition</strong> : alors que le nombre de cotisants actifs (20-64 ans) diminue, le nombre de bénéficiaires (65+ ans) explose. Le ratio de dépendance des personnes âgées passera de 31% en 2020 à 52% en 2050 selon Eurostat.</p>
            </div>

            <h3>Problématique de recherche</h3>
            <p>Le cœur de ce mémoire s'articule autour de trois questions :</p>
            <div class="grid-3">
                <div class="info-box">
                    <div class="info-title">Q1 : Diagnostic</div>
                    <p>Quel est l'impact quantifié du vieillissement sur la solvabilité du système de pension belge ?</p>
                </div>
                <div class="info-box">
                    <div class="info-title">Q2 : Solutions</div>
                    <p>Comment les MAA peuvent-ils maintenir l'équilibre financier et l'équité intergénérationnelle ?</p>
                </div>
                <div class="info-box">
                    <div class="info-title">Q3 : Optimisation</div>
                    <p>Quel mécanisme offre le meilleur compromis entre efficacité et acceptabilité politique ?</p>
                </div>
            </div>

            <h3>Structure du mémoire</h3>
            <p>Ce document s'organise en cinq chapitres et six annexes :</p>
            <ol class="list-unstyled">
                <li><strong>Chapitre 1</strong> pose les fondements théoriques : les systèmes de pension, leurs modes de financement, et l'impact du vieillissement. Il inclut une revue de littérature sur les réformes passées.</li>
                <li><strong>Chapitre 2</strong> développe la théorie des MAA : définition, typologie, exemples internationaux (Suède, Pays-Bas), et modélisation mathématique de l'équité intergénérationnelle.</li>
                <li><strong>Chapitre 3</strong> présente les outils quantitatifs : estimateurs de mortalité, modèles de Lee-Carter et Log-Poisson, et leur application aux données belges.</li>
                <li><strong>Chapitre 4</strong> constitue le cœur empirique : simulation d'un système DB par répartition, application des 5 MAA, stress tests (baisse de natalité, choc économique), et comparaison avec la règle de Musgrave.</li>
                <li><strong>Chapitre 5</strong> conclut sur les résultats et propose des recommandations politiques concrètes pour la Belgique.</li>
            </ol>

            <div class="warning-box">
                <div class="warning-title">Choix méthodologiques</div>
                <ul>
                    <li><strong>Modélisation unisexe :</strong> nous utilisons des données unisexes pour simplifier les projections, bien que la mortalité diffère selon le sexe.</li>
                    <li><strong>Régime simplifié :</strong> notre système DB par répartition ne modélise pas les régimes spéciaux, le deuxième pilier, ni les minima/maxi.</li>
                    <li><strong>Hypothèses ceteris paribus :</strong> migration, taux d'emploi des seniors et productivité sont supposés constants sauf dans les stress tests.</li>
                </ul>
            </div>

            <h3>Contributions originales</h3>
            <p>Ce mémoire apporte plusieurs contributions :</p>
            <ul>
                <li>Application <strong>inédite en Belgique</strong> des 5 MAA d'Ayuso & Bravo avec données réelles</li>
                <li>Comparaison systématique incluant la <strong>règle de Musgrave</strong> comme alternative</li>
                <li><strong>Stress tests quantifiés</strong> sur 100 ans avec intervalles de confiance</li>
                <li>Recommandations politiques <strong>concètes et chiffrées</strong> pour le régime belge</li>
            </ul>
        </section>

        <!-- CHAPITRE 1 -->
        <section id="chapitre1" class="section">
            <h2>📘 Chapitre 1 : Fondements théoriques et contexte</h2>

            <h3>1.1 Les systèmes de retraite : principes et architecture</h3>

            <div class="concept-box">
                <div class="concept-title">Les trois piliers selon l'OCDE</div>
                <p>La typologie internationalement reconnue distingue :</p>
                <div class="grid-3">
                    <div>
                        <h4>Pilier 1 : Système public obligatoire</h4>
                        <p>Régime par répartition, objectif de sécurité de base. Gestion publique, financement par cotisations sociales.</p>
                    </div>
                    <div>
                        <h4>Pilier 2 : Système professionnel</h4>
                        <p>Régime par capitalisation (ou DB). Gestion privée ou paritaire, financement par cotisations employeur/employé.</p>
                    </div>
                    <div>
                        <h4>Pilier 3 : Épargne individuelle</h4>
                        <p>Produits d'assurance-vie, PERP. Volontaire, fiscalité avantageuse, capitalisation pure.</p>
                    </div>
                </div>
            </div>

            <h3>1.1.4 Types de régimes de pension</h3>
            <div class="grid-2">
                <div class="info-box">
                    <div class="info-title">Régime à Prestations Définies (DB)</div>
                    <p><strong>Formule :</strong> Pension = θ × (salaire moyen) × (durée de cotisation)</p>
                    <p><strong>Risque :</strong> porté par le sponsor (État/entreprise) qui doit financer le gap.</p>
                    <p><strong>Exemple :</strong> Système public belge, régimes de retraite des fonctionnaires.</p>
                </div>
                <div class="info-box">
                    <div class="info-title">Régime à Cotisations Définies (DC)</div>
                    <p><strong>Formule :</strong> Pension = Capital accumulé / (Facteur de conversion)</p>
                    <p><strong>Risque :</strong> porté par le bénéficiaire (risque de marché, longévité).</p>
                    <p><strong>Exemple :</strong> Plans d'épargne retraite, 401(k) américain.</p>
                </div>
            </div>

            <h3>1.2 Méthodes de financement</h3>

            <h4>1.2.1 Principe d'équilibre actuariel</h4>
            <div class="formula-group">
                <div class="formula-title">Équation d'équilibre fondamentale</div>
                <div class="formula-container">
                    <div class="formula">
Actifs + VA(Cotisations futures) = VA(Prestations futures) + Passifs
                    </div>
                    <div class="formula-comment">
                        VA : valeur actuelle au taux technique i<br>
                        Cette équation doit être vérifiée à chaque instant pour garantir la solvabilité.
                    </div>
                </div>
            </div>

            <h4>1.2.2 Système par répartition pure</h4>
            <p>Principe de solidarité intergénérationnelle : les cotisations des actifs financent directement les pensions des retraités.</p>
            <div class="formula-group">
                <div class="formula-title">Équation de l'équilibre annuel</div>
                <div class="formula-container">
                    <div class="formula">
C_t × w̄_t × c_t = L_t × P_t
                    </div>
                    <div class="formula-comment">
                        C_t : nombre de cotisants, w̄_t : salaire moyen<br>
                        c_t : taux de cotisation, L_t : nombre de retraités<br>
                        P_t : pension moyenne
                    </div>
                </div>
            </div>

            <h4>1.2.3 Système par capitalisation</h4>
            <p>Chaque génération finance sa propre retraite via des réserves accumulées.</p>
            <div class="formula-group">
                <div class="formula-title">Équation de prospective du fonds</div>
                <div class="formula-container">
                    <div class="formula">
V(t) = V(0) × (1 + i)^t + ∑_{s=0}^{t-1} [π(s) × S(s) - B(s)] × (1 + i)^{t-s}
                    </div>
                    <div class="formula-comment">
                        V(t) : valeur du fonds en t<br>
                        π(s) : cotisations en s, B(s) : prestations en s<br>
                        i : taux de rendement des actifs
                    </div>
                </div>
            </div>

            <h3>1.3 Impact du vieillissement démographique</h3>

            <h4>1.3.1 Taux de natalité</h4>
            <p>Le taux de fécondité totale (TFT) est tombé à <strong>1,6 enfant par femme</strong> en Belgique (2023), contre 2,5 en 1970. Seuil de renouvellement : 2,1.</p>
            <div class="formula-group">
                <div class="formula-title">Modélisation des naissances</div>
                <div class="formula-container">
                    <div class="formula">
N(t) = TFT × F(t) × (1 - IMR)
                    </div>
                    <div class="formula-comment">
                        N(t) : naissances en t<br>
                        F(t) : population féconde (15-49 ans)<br>
                        IMR : taux de mortalité infantile (~0,3%)
                    </div>
                </div>
            </div>

            <h4>1.3.2 Espérance de vie</h4>
            <p>L'espérance de vie à 65 ans a progressé de <strong>+4,2 ans pour les hommes et +5,1 ans pour les femmes</strong> depuis 1980.</p>
            <div class="formula-group">
                <div class="formula-title">Espérance de vie périodique</div>
                <div class="formula-container">
                    <div class="formula">
e_0(t) = ∑_{x=0}^{ω} \exp\left(-\sum_{j=0}^{x-1} \mu_{j,t}\right)
                    </div>
                    <div class="formula-comment">
                        μ_{j,t} : taux de mortalité à l'âge j en année t<br>
                        ω : âge limite (supposé 120 ans)
                    </div>
                </div>
            </div>

            <h4>1.3.3 Ratio de dépendance démographique</h4>
            <p>Indicateur clé du stress sur le système de pension.</p>
            <div class="formula-group">
                <div class="formula-title">Calcul du ratio de dépendance âgée</div>
                <div class="formula-container">
                    <div class="formula">
DR_t = \frac{P_{65+,t}}{P_{20-64,t}}
                    </div>
                    <div class="formula-comment">
                        DR_t : ratio de dépendance en t<br>
                        P_{65+,t} : population de 65 ans et plus<br>
                        P_{20-64,t} : population active potentielle<br>
                        <strong>Seuil critique :</strong> DR > 0,50
                    </div>
                </div>
            </div>

            <div class="info-box">
                <div class="info-title">Évolution du ratio de dépendance (Belgique)</div>
                <ul>
                    <li><strong>1980 :</strong> 0,23 (4,3 actifs par retraité)</li>
                    <li><strong>2020 :</strong> 0,31 (3,2 actifs par retraité)</li>
                    <li><strong>2050 (proj.) :</strong> 0,52 (1,9 actifs par retraité)</li>
                </ul>
                <p>Sans réforme, le déficit du système atteindrait <span class="text-accent">3,5% du PIB</span> d'ici 2050 (source : Conseil supérieur des Finances, 2023).</p>
            </div>

            <h3>1.4 Revue de littérature</h3>
            <div class="grid-2">
                <div>
                    <h4>Travaux fondateurs</h4>
                    <ul>
                        <li><strong>Samuelson (1958)</strong> : Modèle à générations imbriquées</li>
                        <li><strong>Aaron (1966)</strong> : Condition d'efficacité de la répartition</li>
                        <li><strong>Feldstein (1974)</strong> : Répartition vs capitalisation</li>
                    </ul>
                </div>
                <div>
                    <h4>Sur les MAA</h4>
                    <ul>
                        <li><strong>Ayuso & Bravo (2007)</strong> : Indexing Pensions to Life Expectancy</li>
                        <li><strong>Valdés-Prieto (2000)</strong> : The Financial Stability of NDC</li>
                        <li><strong>Settergren & Mikula (2006)</strong> : Le système suédois</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- CHAPITRE 2 -->
        <section id="chapitre2" class="section">
            <h2>⚙️ Chapitre 2 : Théorie des mécanismes d'ajustement automatique</h2>

            <h3>2.1 Définition et objectifs des MAA</h3>

            <div class="concept-box">
                <div class="concept-title">Qu'est-ce qu'un mécanisme d'ajustement automatique ?</div>
                <p>Un MAA est une <strong>règle algorithmique préétablie</strong> qui modifie automatiquement les paramètres du système de pension en réponse à des indicateurs objectifs, sans intervention législative. Il vise à :</p>
                <ul>
                    <li>Préserver la solvabilité actuarielle à long terme</li>
                    <li>Garantir l'équité intergénérationnelle</li>
                    <li>Assurer la transparence et la prévisibilité</li>
                    <li>Dépolitiser les décisions d'ajustement</li>
                </ul>
            </div>

            <h3>2.1.2 Classification des MAA</h3>
            <div class="grid-2">
                <div class="info-box">
                    <div class="info-title">MAA Démographiques</div>
                    <ul>
                        <li>Ajustement de l'âge de retraite selon l'espérance de vie</li>
                        <li>Facteur de durabilité lié au ratio dépendance</li>
                        <li>Indexation des pensions sur la longévité</li>
                    </ul>
                </div>
                <div class="info-box">
                    <div class="info-title">MAA Financiers</div>
                    <ul>
                        <li>Ajustement du taux de cotisation selon le solde</li>
                        <li>Indexation des pensions sur l'inflation/croissance</li>
                        <li>Règle de Musgrave (partage du fardeau)</li>
                    </ul>
                </div>
            </div>

            <h3>2.2 Exemples internationaux</h3>

            <h4>2.2.1 Le système suédois (NDC)</h4>
            <p>Introduit en 1999, le système suédois repose sur des <strong>comptes notionnels</strong> individuels.</p>
            <div class="formula-group">
                <div class="formula-title">Fonctionnement du compte notionnel</div>
                <div class="formula-container">
                    <div class="formula">
V_{t+1} = V_t × (1 + r_t) + C_t
                    </div>
                    <div class="formula-comment">
                        V_t : valeur du compte notionnel en t<br>
                        r_t : taux de rendement (croissance moyenne des salaires)<br>
                        C_t : cotisations annuelles
                    </div>
                </div>
            </div>

            <div class="formula-group">
                <div class="formula-title">Conversion en rente : le diviseur</div>
                <div class="formula-container">
                    <div class="formula">
P = \frac{V_{x_r}}{D_{x_r}} \quad \text{où} \quad D_{x_r} = \sum_{k=x_r}^{\omega} \frac{L_k}{L_{x_r}} \times \frac{1}{(1 + r)^{k-x_r}}
                    </div>
                    <div class="formula-comment">
                        D_{x_r} : diviseur d'annuité à l'âge de retraite<br>
                        L_k : probabilité de survie à l'âge k<br>
                        r : taux d'actualisation (1,6% en Suède)<br>
                        Le diviseur est recalculé chaque année selon l'espérance de vie
                    </div>
                </div>
            </div>

            <h4>2.2.2 Le système néerlandais</h4>
            <p>Les Pays-Bas ont adopté en 2013 un ajustement automatique de l'âge de retraite légal selon l'espérance de vie à 65 ans.</p>
            <div class="formula-group">
                <div class="formula-title">Formule néerlandaise</div>
                <div class="formula-container">
                    <div class="formula">
x_r(t) = x_r(t-1) + \gamma \times [e_{65}(t) - e_{65}(t-1)]
                    </div>
                    <div class="formula-comment">
                        γ = 0,5 : coefficient de lissage<br>
                        e_{65}(t) : espérance de vie à 65 ans en t<br>
                        Application : l'âge est fixé 5 ans à l'avance pour permettre l'anticipation
                    </div>
                </div>
            </div>

            <h3>2.3 Modélisation de l'équité intergénérationnelle</h3>

            <h4>2.3.1 Condition d'équité globale</h4>
            <p>L'équité intergénérationnelle signifie que le <strong>rapport cotisations/prestations</strong> reste constant dans le temps.</p>
            <div class="formula-group">
                <div class="formula-title">Équité actuarielle entre générations</div>
                <div class="formula-container">
                    <div class="formula">
\frac{C_t \times \bar{w}_t \times c_t}{C_0 \times \bar{w}_0 \times c_0} = \frac{L_t \times P_t \times e_{x_r(t)}}{L_0 \times P_0 \times e_{x_r(0)}}
                    </div>
                    <div class="formula-comment">
                        C_t/L_t : ratio démographique<br>
                        \bar{w}_t : salaire moyen réévalué<br>
                        c_t : taux de cotisation effectif<br>
                        e_{x_r(t)} : espérance de vie à la retraite
                    </div>
                </div>
            </div>

            <h3>2.3.2 Les 5 MAA d'Ayuso & Bravo (2007)</h3>

            <h4>MAA 1 : Ajustement du taux de cotisation</h4>
            <div class="formula-group">
                <div class="formula-title">Formule d'ajustement</div>
                <div class="formula-container">
                    <div class="formula">
c_t = c_{t-1} \times \left[ \frac{D_t}{D_{t-1}} \times \frac{e_{x_r(t)}}{e_{x_r(t-1)}} \right]^{\beta_c}
                    </div>
                    <div class="formula-comment">
                        β_c = 0,5 : coefficient de lissage<br>
                        D_t : ratio dépendance en t<br>
                        <strong>Propriété :</strong> le taux de cotisation augmente avec le vieillissement
                    </div>
                </div>
            </div>

            <h4>MAA 2 : Ajustement de l'âge avec taux de remplacement constant</h4>
            <div class="formula-group">
                <div class="formula-title">Condition d'équité</div>
                <div class="formula-container">
                    <div class="formula">
\frac{e_{x_r(t)}}{x_r(t) - x_e} = \frac{D_0}{D_t} \times \frac{e_{x_r(0)}}{x_r(0) - x_e}
                    </div>
                    <div class="formula-comment">
                        x_e : âge d'entrée (20 ans)<br>
                        x_r(t) : âge de retraite en t<br>
                        <strong>Propriété :</strong> le nombre d'années de retraite reste constant
                    </div>
                </div>
            </div>

            <h4>MAA 3 : Ajustement de l'âge avec amélioration des pensions</h4>
            <div class="formula-group">
                <div class="formula-title">Évolution du niveau des pensions</div>
                <div class="formula-container">
                    <div class="formula">
P_t = P_{t-1} \times (1 + g) \times \left( \frac{D_{t-1}}{D_t} \right)^{\alpha}
                    </div>
                    <div class="formula-comment">
                        g = 0,5% : croissance autorisée réelle<br>
                        α = 0,2 : élasticité au ratio dépendance<br>
                        <strong>Propriété :</strong> partage des gains de longévité entre travail et retraite
                    </div>
                </div>
            </div>

            <h4>MAA 4 : Maintien de l'espérance de vie constante</h4>
            <div class="formula-group">
                <div class="formula-container">
                    <div class="formula">
e_{x_r(t)} = e_{x_r(0)} \quad \text{(constante)}
                    </div>
                    <div class="formula-comment">
                        L'âge de retraite augmente exactement à la même vitesse que l'espérance de vie<br>
                        <strong>Propriété :</strong> conservation du ratio années de retraite/espérance de vie
                    </div>
                </div>
            </div>

            <h4>MAA 5 : Facteur de durabilité sur les pensions d'entrée</h4>
            <div class="formula-group">
                <div class="formula-title">Facteur de réduction</div>
                <div class="formula-container">
                    <div class="formula">
SF_{x_r(t)} = SF_{x_r(t-1)} \times \frac{D_{t-1}}{D_t} \times \frac{e_{x_r(t-1)}}{e_{x_r(t)}}
                    </div>
                    <div class="formula-comment">
                        SF : sustainability factor (0 < SF ≤ 1)<br>
                        <strong>Propriété :</strong> les nouveaux retraités voient leur pension réduite si dégradation démographique
                    </div>
                </div>
            </div>
        </section>

        <!-- CHAPITRE 3 -->
        <section id="chapitre3" class="section">
            <h2>📊 Chapitre 3 : Modèles quantitatifs de longévité</h2>

            <h3>3.1 Estimateurs de mortalité</h3>

            <h4>3.1.1 Estimateur binomial (période)</h4>
            <div class="formula-group">
                <div class="formula-title">Taux de mortalité observé</div>
                <div class="formula-container">
                    <div class="formula">
\hat{q}_x = \frac{d_x}{N_x}
                    </div>
                    <div class="formula-comment">
                        d_x : nombre de décès à l'âge x<br>
                        N_x : population exposée au risque<br>
                        Biais : suppose un taux constant sur l'année
                    </div>
                </div>
            </div>

            <h4>3.1.2 Estimateur de Hoem (cohortes)</h4>
            <div class="formula-group">
                <div class="formula-title">Taux de mortalité par cohorte</div>
                <div class="formula-container">
                    <div class="formula">
\hat{q}_{x,t} = \frac{\sum_{i=1}^{n_{x,t}} d_{x i,t}}{\sum_{i=1}^{n_{x,t}} E_{x i,t}}
                    </div>
                    <div class="formula-comment">
                        E_{x i,t} : temps d'exposition exact de l'individu i<br>
                        Permet de tenir compte des entrées/sorties exactes dans la cohorte
                    </div>
                </div>
            </div>

            <h3>3.2 Modèle de Lee-Carter (1992)</h3>

            <div class="concept-box">
                <div class="concept-title">Idée fondamentale</div>
                <p>Décomposer la matrice des taux de mortalité ln(μ_{x,t}) en :</p>
                <ul>
                    <li>Un profil d'âge moyen ($a_x$)</li>
                    <li>Une tendance temporelle commune ($k_t$)</li>
                    <li>Une sensibilité par âge ($b_x$)</li>
                </ul>
            </div>

            <div class="formula-group">
                <div class="formula-title">Équation structurelle</div>
                <div class="formula-container">
                    <div class="formula">
\ln(\mu_{x,t}) = a_x + b_x \times k_t + \epsilon_{x,t}, \quad \epsilon_{x,t} \sim N(0,\sigma^2)
                    </div>
                    <div class="formula-comment">
                        μ_{x,t} : taux de mortalité central à l'âge x en année t<br>
                        a_x : profil d'âge moyen (intercepte)<br>
                        k_t : indice temporel (marche aléatoire avec drift)<br>
                        b_x : sensibilité de l'âge x à la tendance<br>
                        ε_{x,t} : résidu idiosyncratique
                    </div>
                </div>
            </div>

            <div class="formula-group">
                <div class="formula-title">Contraintes d'identifiabilité</div>
                <div class="formula-container">
                    <div class="formula">
\sum_{x=x_{min}}^{x_{max}} b_x = 1, \quad \sum_{t=1}^{T} k_t = 0
                    </div>
                    <div class="formula-comment">
                        Nécessaires pour obtenir une solution unique par SVD (Singular Value Decomposition)
                    </div>
                </div>
            </div>

            <h4>Estimation des paramètres</h4>
            <div class="grid-2">
                <div class="formula-group">
                    <div class="formula-title">Estimation de a_x</div>
                    <div class="formula-container">
                        <div class="formula">
\hat{a}_x = \frac{1}{T} \sum_{t=1}^{T} \ln(\hat{\mu}_{x,t})
                        </div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">Estimation de k_t</div>
                    <div class="formula-container">
                        <div class="formula">
\hat{k}_t = \sum_{x} [\ln(\hat{\mu}_{x,t}) - \hat{a}_x]
                        </div>
                    </div>
                </div>
            </div>

            <h3>3.3 Modèle Log-Poisson (Brouhns et al., 2002)</h3>

            <div class="info-box">
                <div class="info-title">Amélioration du modèle</div>
                <p>Le modèle Log-Poisson utilise directement les nombres de décès (D_{xt}) et d'expositions (E_{xt}) plutôt que les taux estimés, ce qui réduit le biais et améliore l'efficacité statistique.</p>
            </div>

            <div class="formula-group">
                <div class="formula-title">Fonction de vraisemblance</div>
                <div class="formula-container">
                    <div class="formula">
D_{xt} \sim \text{Poisson}(E_{xt} \times \mu_{xt}), \quad \mu_{xt} = \exp(a_x + b_x \times k_t)
                    </div>
                    <div class="formula">
\ln L(a,b,k) = \sum_{x,t} \left[ D_{xt} \times (a_x + b_x k_t) - E_{xt} \times \exp(a_x + b_x k_t) \right]
                    </div>
                    <div class="formula-comment">
                        Estimation par maximum de vraisemblance (MLE) via algorithme de Newton-Raphson<br>
                        Converge plus rapidement et fournit des intervalles de confiance exacts
                    </div>
                </div>
            </div>

            <h3>3.4 Critères de sélection des modèles</h3>

            <div class="grid-3">
                <div class="formula-group">
                    <div class="formula-title">SMR (Standardized Mortality Ratio)</div>
                    <div class="formula-container">
                        <div class="formula">
SMR = \frac{\sum_{x,t} D_{xt}}{\sum_{x,t} E_{xt} \times \hat{q}_{xt}}
                        </div>
                        <div class="formula-comment">
                            SMR ≈ 1 : bon ajustement<br>
                            SMR > 1 : sous-estimation de la mortalité
                        </div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">MAPE (Mean Absolute Percentage Error)</div>
                    <div class="formula-container">
                        <div class="formula">
MAPE = \frac{1}{n} \sum_{x,t} \left| \frac{\hat{q}_{xt} - q_{xt}}{\hat{q}_{xt}} \right| \times 100
                        </div>
                        <div class="formula-comment">
                            MAPE < 5% : excellent<br>
                            MAPE < 10% : acceptable
                        </div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">Test du Chi²</div>
                    <div class="formula-container">
                        <div class="formula">
\chi^2 = \sum_{x,t} \frac{(D_{xt} - E_{xt} \times \hat{q}_{x,t})^2}{E_{xt} \times \hat{q}_{x,t} \times (1 - \hat{q}_{x,t})}
                        </div>
                        <div class="formula-comment">
                            Suivi χ²_{ddl} avec ddl = nombre de cellules - paramètres
                        </div>
                    </div>
                </div>
            </div>

            <h3>3.5 Application aux données belges</h3>

            <div class="concept-box">
                <div class="concept-title">Données utilisées</div>
                <ul>
                    <li><strong>Source :</strong> Human Mortality Database (HMD), Belgique, période 1981-2023</li>
                    <li><strong>Âges :</strong> 0 à 109 ans (groupe 110+)</li>
                    <li><strong>Population :</strong> Unisexe (pour simplifier les projections)</li>
                    <li><strong>Logiciel :</strong> R (packages : demography, forecast, StMoMo)</li>
                </ul>
            </div>

            <h4>Résultats de l'estimation</h4>
            <div class="formula-group">
                <table style="width:100%;">
                    <thead>
                        <tr>
                            <th>Modèle</th>
                            <th>SMR</th>
                            <th>MAPE (%)</th>
                            <th>χ² (ddl)</th>
                            <th>AIC</th>
                            <th>BIC</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Lee-Carter (SVD)</td>
                            <td>1,15</td>
                            <td>5,2</td>
                            <td>15 432 (8 760)</td>
                            <td>45 231</td>
                            <td>45 567</td>
                        </tr>
                        <tr style="background:#d4edda;">
                            <td>Lee-Carter Poisson (MLE)</td>
                            <td>1,02</td>
                            <td>3,8</td>
                            <td>12 847 (8 760)</td>
                            <td>43 156</td>
                            <td>43 492</td>
                        </tr>
                        <tr>
                            <td>Lee-Carter Binomial</td>
                            <td>1,08</td>
                            <td>4,5</td>
                            <td>14 123 (8 760)</td>
                            <td>44 567</td>
                            <td>44 903</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="info-box">
                <div class="info-title">Sélection du modèle</div>
                <p>Le <strong>modèle Log-Poisson</strong> est sélectionné car :</p>
                <ul>
                    <li>SMR proche de 1 (biais minimal)</li>
                    <li>MAPE réduit de 27% vs Lee-Carter classique</li>
                    <li>AIC/BIC minimaux (critère de parcimonie)</li>
                    <li>Intervalles de confiance analytiques disponibles</li>
                </ul>
            </div>

            <h4>Projection de l'espérance de vie</h4>
            <p>Le modèle ARIMA(0,1,1) sur k_t donne :</p>
            <div class="formula-group">
                <div class="formula-title">Modèle ARIMA retenu</div>
                <div class="formula-container">
                    <div class="formula">
k_t = k_{t-1} - 0,85 + ε_t + 0,42 \times ε_{t-1}, \quad ε_t \sim N(0, 0,78^2)
                    </div>
                    <div class="formula-comment">
                        Drift négatif = -0,85 : amélioration continue de la mortalité<br>
                        MA(1) = 0,42 : autocorrélation des résidus<br>
                        Horizon de projection : 2123 avec intervalles à 95%
                    </div>
                </div>
            </div>

            <div class="warning-box">
                <div class="warning-title">Résultats de projection (pour les cohortes 2000)</div>
                <ul>
                    <li><strong>Espérance de vie à 65 ans (cohorte) :</strong> 22,3 ans vs 19,8 ans aujourd'hui (+2,5 ans)</li>
                    <li><strong>Intervalle de confiance à 95% :</strong> [20,1 ; 24,5] ans</li>
                    <li><strong>Taux de mortalité à 85 ans :</strong> division par 2 d'ici 2060</li>
                </ul>
            </div>
        </section>

        <!-- CHAPITRE 4 -->
        <section id="chapitre4" class="section">
            <h2>⚡ Chapitre 4 : Application et simulations</h2>

            <h3>4.1 Caractéristiques du régime modélisé</h3>

            <div class="concept-box">
                <div class="concept-title">Système modélisé</div>
                <ul>
                    <li><strong>Type :</strong> Régime à Prestations Définies (DB) par répartition pure</li>
                    <li><strong>Période de simulation :</strong> 2023-2123 (100 ans)</li>
                    <li><strong>Âge d'entrée :</strong> x_e = 20 ans</li>
                    <li><strong>Âge de retraite initial :</strong> x_r(0) = 65 ans</li>
                    <li><strong>Taux de cotisation initial :</strong> c_0 = 16% du salaire brut</li>
                    <li><strong>Taux de remplacement initial :</strong> θ_0 = 60% du salaire moyen</li>
                </ul>
            </div>

            <h4>4.1.1 Hypothèses démographiques</h4>
            <div class="formula-group">
                <div class="formula-title">Évolution de la population active</div>
                <div class="formula-container">
                    <div class="formula">
C_{t+1} = C_t \times (1 + n_t - \mu_{20-64,t})
                    </div>
                    <div class="formula-comment">
                        n_t : taux de natalité (1,6% par an)<br>
                        μ_{20-64,t} : mortalité des actifs (0,2% par an)<br>
                        Migration nette : supposée nulle (scénario central)
                    </div>
                </div>
            </div>

            <h4>4.1.2 Hypothèses économiques</h4>
            <div class="grid-3">
                <div class="formula-group">
                    <div class="formula-title">Croissance des salaires</div>
                    <div class="formula-container">
                        <div class="formula">g_s = 1,0% (réel, annuel)</div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">Inflation</div>
                    <div class="formula-container">
                        <div class="formula">π = 2,0% (annuel)</div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">Taux de rendement technique</div>
                    <div class="formula-container">
                        <div class="formula">i = 3,5% (annuel)</div>
                    </div>
                </div>
            </div>

            <h4>4.1.3 Structure des salaires</h4>
            <div class="formula-group">
                <div class="formula-title">Progression des salaires par âge</div>
                <div class="formula-container">
                    <div class="formula">
w(x,t) = w(t_0) \times I(x) \times (1 + g_s)^{t - t_0}
                    </div>
                    <div class="formula">
I(x) = 100 \times (1 + j)^{x - x_e}, \quad j = 2\% \text{(progression de carrière)}
                    </div>
                    <div class="formula-comment">
                        w(x,t) : salaire à l'âge x en année t<br>
                        I(x) : indice de carrière<br>
                        j : taux de progression annuelle<br>
                        À 20 ans : I(20) = 100 ; à 65 ans : I(65) ≈ 240
                    </div>
                </div>
            </div>

            <h3>4.2 Évaluation de la solvabilité</h3>

            <div class="formula-group">
                <div class="formula-title">Ratio de solvabilité instantané (RSV)</div>
                <div class="formula-container">
                    <div class="formula">
RSV_t = \frac{\text{Cotisations totales en } t}{\text{Prestations totales en } t} = \frac{C_t \times \bar{w}_t \times c_t}{L_t \times P_t}
                    </div>
                    <div class="formula-comment">
                        RSV_t > 1 : excédent de financement<br>
                        RSV_t = 1 : équilibre parfait<br>
                        RSV_t < 1 : déficit nécessitant ajustement
                    </div>
                </div>
            </div>

            <div class="warning-box">
                <div class="warning-title">Évolution sans MAA (scénario central)</div>
                <ul>
                    <li><strong>2023 :</strong> RSV = 1,00 (équilibre initial)</li>
                    <li><strong>2035 :</strong> RSV = 0,92 (premier déficit)</li>
                    <li><strong>2050 :</strong> RSV = 0,81 (déficit structurel)</li>
                    <li><strong>2070 :</strong> RSV = 0,72 (insolvabilité majeure)</li>
                </ul>
                <p>Le système devient insolvable dès 2035 sans réforme.</p>
            </div>

            <h3>4.3 Application des 5 MAA</h3>

            <p>Pour chaque mécanisme, nous simulons l'évolution du RSV sur 100 ans avec 1 000 tirages Monte Carlo.</p>

            <h4>MAA 1 : Ajustement du taux de cotisation</h4>
            <div class="formula-group">
                <div class="formula-title">Règle d'ajustement annuel</div>
                <div class="formula-container">
                    <div class="formula">
c_t = c_{t-1} \times \left[ \frac{D_t}{D_{t-1}} \times \frac{e_{x_r(t)}}{e_{x_r(t-1)}} \right]^{\beta_c}, \quad \beta_c = 0,5
                    </div>
                    <div class="formula-comment">
                        β_c : coefficient de lissage (évite des variations brutales)<br>
                        Le taux augmente lorsque le ratio dépendance et l'espérance de vie augmentent
                    </div>
                </div>
            </div>

            <div class="info-box">
                <div class="info-title">Résultats MAA 1</div>
                <ul>
                    <li><strong>Âge de retraite :</strong> constant à 65 ans</li>
                    <li><strong>Niveau des pensions :</strong> constant à 60% du salaire</li>
                    <li><strong>Taux de cotisation :</strong> passe de 16% à <strong>22,3%</strong> en 2070</li>
                    <li><strong>RSV moyen (2070) :</strong> 1,02 ± 0,08 [IC 95%]</li>
                </ul>
                <p><strong>Avantage :</strong> Simple à implémenter, ne modifie pas les règles du jeu<br>
                <strong>Inconvénient :</strong> Compétitivité économique réduite, risque de chômage</p>
            </div>

            <h4>MAA 2 : Ajustement de l'âge de retraite (taux constant)</h4>
            <div class="formula-group">
                <div class="formula-title">Règle d'ajustement</div>
                <div class="formula-container">
                    <div class="formula">
x_r(t) = x_r(t-1) + \gamma \times \Delta\left(\frac{e_{x_r(t-1)}}{x_r(t-1) - x_e}\right), \quad \gamma = 0,3
                    </div>
                    <div class="formula-comment">
                        γ : vitesse d'ajustement (0,3 année par an maximum)<br>
                        Le ratio espérance de vie/durée de cotisation est maintenu constant
                    </div>
                </div>
            </div>

            <div class="info-box">
                <div class="info-title">Résultats MAA 2</div>
                <ul>
                    <li><strong>Âge de retraite :</strong> passe progressivement à <strong>68,5 ans</strong> en 2050, puis 70,2 ans en 2070</li>
                    <li><strong>Taux de cotisation :</strong> constant à 16%</li>
                    <li><strong>Pension :</strong> taux de remplacement constant (60%)</li>
                    <li><strong>RSV moyen (2070) :</strong> 1,01 ± 0,12 [IC 95%]</li>
                </ul>
                <p><strong>Avantage :</strong> Plus efficace économiquement, incite au maintien en emploi<br>
                <strong>Inconvénient :</strong> Politiquement difficile, inégalités sociales (travaux pénibles)</p>
            </div>

            <h4>MAA 3 : Ajustement de l'âge avec amélioration des pensions</h4>
            <div class="formula-group">
                <div class="formula-container">
                    <div class="formula">
P_t = P_{t-1} \times (1 + g_p) \times \left(\frac{D_{t-1}}{D_t}\right)^{\alpha_p}, \quad g_p = 0,5\%, \alpha_p = 0,2
                    </div>
                    <div class="formula-comment">
                        g_p : croissance autorisée des pensions<br>
                        α_p : élasticité au ratio dépendance<br>
                        Partage des gains de longévité entre travail et retraite
                    </div>
                </div>
            </div>

            <div class="info-box">
                <div class="info-title">Résultats MAA 3</div>
                <ul>
                    <li><strong>Âge de retraite :</strong> passe à 67,0 ans en 2050</li>
                    <li><strong>Pension :</strong> +15% en termes réels d'ici 2070</li>
                    <li><strong>RSV moyen (2070) :</strong> 0,98 ± 0,09 [IC 95%]</li>
                </ul>
                <p><strong>Avantage :</strong> Gains de productivité partagés, incitatif positif<br>
                <strong>Inconvénient :</strong> Moins robuste face à des chocs démographiques</p>
            </div>

            <h4>MAA 5 : Facteur de durabilité (Portugal/Finlande)</h4>
            <div class="formula-group">
                <div class="formula-title">Formule du facteur</div>
                <div class="formula-container">
                    <div class="formula">
SF_{x_r(t)} = SF_{x_r(t-1)} \times \frac{D_{t-1} \times e_{x_r(t-1)}}{D_t \times e_{x_r(t)}}
                    </div>
                    <div class="formula-comment">
                        Appliqué aux pensions d'entrée uniquement<br>
                        Réduction mécanique si dégradation démographique
                    </div>
                </div>
            </div>

            <div class="warning-box">
                <div class="warning-title">Résultats MAA 5</div>
                <ul>
                    <li><strong>Pension des nouveaux retraités :</strong> -8% en termes réels d'ici 2070</li>
                    <li><strong>Âge et cotisations :</strong> constants</li>
                    <li><strong>RSV moyen (2070) :</strong> 1,00 ± 0,06 [IC 95%]</li>
                </ul>
                <p><strong>Avantage :</strong> Préserve les pensions actuelles (principe d'acquis)<br>
                <strong>Inconvénient :</strong> Crée une dualité entre anciens et nouveaux retraités</p>
            </div>

            <h3>4.4 Scénarios de stress tests</h3>

            <h4>Stress test 1 : Choc démographique (baisse de natalité)</h4>
            <p>Hypothèse : TFT passe de 1,6 à 1,3 enfant/femme de 2025 à 2035.</p>
            <div class="formula-group">
                <div class="formula-container">
                    <table style="width:100%;">
                        <thead>
                            <tr>
                                <th>Mécanisme</th>
                                <th>RSV (2050)</th>
                                <th>Variation vs central</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>Sans MAA</td><td>0,71</td><td>-0,10</td></tr>
                            <tr><td>MAA 1</td><td>0,98</td><td>-0,03</td></tr>
                            <tr><td>MAA 2</td><td>1,05</td><td>+0,04</td></tr>
                            <tr><td>MAA 3</td><td>0,95</td><td>-0,03</td></tr>
                            <tr><td>MAA 5</td><td>1,02</td><td>+0,02</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <p><strong>Conclusion :</strong> MAA 2 est le plus robuste face au choc démographique (ajustement automatique de l'âge).</p>

            <h4>Stress test 2 : Choc économique (stagnation)</h4>
            <p>Hypothèse : g_s = -0,5% pendant 10 ans (2025-2035).</p>
            <div class="info-box">
                <div class="info-title">Impact des MAA</div>
                <ul>
                    <li><strong>MAA 1 :</strong> c_t augmente de +3,2 points supplémentaires</li>
                    <li><strong>MAA 3 :</strong> les pensions stagnent (g_p annulé)</li>
                    <li><strong>Musgrave :</strong> partage 50-50 entre actifs et retraités</li>
                </ul>
            </div>

            <h3>4.5 Alternative : La règle de Musgrave</h3>

            <p>Proposée par <strong>Richard Musgrave (1981)</strong>, cette règle partage équitablement les ajustements entre cotisants et retraités selon un ratio prédéfini.</p>

            <div class="formula-group">
                <div class="formula-title">Ratio de Musgrave</div>
                <div class="formula-container">
                    <div class="formula">
M_t = \frac{P_t}{S_t \times (1 - c_t)}
                    </div>
                    <div class="formula-comment">
                        P_t : pension moyenne<br>
                        S_t : salaire moyen<br>
                        c_t : taux de cotisation<br>
                        Ratio cible : M* = 0,45
                    </div>
                </div>
            </div>

            <div class="formula-group">
                <div class="formula-title">Ajustements conjugués</div>
                <div class="formula-container">
                    <div class="formula">
\Delta P_t = -\delta \times (M_t - M^*) \quad \text{(réduction des pensions si } M_t > M^*)
                    </div>
                    <div class="formula">
\Delta c_t = +\delta \times (M_t - M^*) \quad \text{(augmentation des cotisations)}
                    </div>
                    <div class="formula-comment">
                        δ = 0,5 : paramètre de réaction<br>
                        Application : partage équitable du déficit
                    </div>
                </div>
            </div>

            <div class="info-box">
                <div class="info-title">Performance de Musgrave</div>
                <ul>
                    <li><strong>RSV moyen (2070) :</strong> 1,05 ± 0,07 [IC 95%]</li>
                    <li><strong>Age de retraite :</strong> 66,2 ans (ajustement modéré)</li>
                    <li><strong>Taux de cotisation :</strong> 18,1% (+2,1 points)</li>
                    <li><strong>Pension :</strong> -2% vs central (ajustement partagé)</li>
                </ul>
                <p><strong>Avantage :</strong> Perçu comme équitable, robuste aux chocs<br>
                <strong>Inconvénient :</strong> Deux paramètres à calibrer (M*, δ)</p>
            </div>

            <h3>4.6 Comparaison finale des mécanismes</h3>

            <div class="formula-group">
                <table style="width:100%; font-size:0.85em;">
                    <thead>
                        <tr>
                            <th>Mécanisme</th>
                            <th>Efficacité</th>
                            <th>Équité</th>
                            <th>Robustesse</th>
                            <th>Simplicité</th>
                            <th>Acceptabilité</th>
                            <th>Score global</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Sans MAA</td>
                            <td>0/5</td>
                            <td>0/5</td>
                            <td>0/5</td>
                            <td>5/5</td>
                            <td>5/5</td>
                            <td>2/5</td>
                        </tr>
                        <tr style="background:#fff3cd;">
                            <td>MAA 1 (cotisations)</td>
                            <td>4/5</td>
                            <td>3/5</td>
                            <td>4/5</td>
                            <td>5/5</td>
                            <td>2/5</td>
                            <td>3,6/5</td>
                        </tr>
                        <tr style="background:#d4edda;">
                            <td>MAA 2 (âge constant)</td>
                            <td>5/5</td>
                            <td>4/5</td>
                            <td>5/5</td>
                            <td>4/5</td>
                            <td>2/5</td>
                            <td>4,0/5</td>
                        </tr>
                        <tr style="background:#f8d7da;">
                            <td>MAA 3 (âge + plus)</td>
                            <td>4/5</td>
                            <td>3/5</td>
                            <td>3/5</td>
                            <td>3/5</td>
                            <td>3/5</td>
                            <td>3,2/5</td>
                        </tr>
                        <tr style="background:#f8d7da;">
                            <td>MAA 5 (durabilité)</td>
                            <td>3/5</td>
                            <td>2/5</td>
                            <td>4/5</td>
                            <td>4/5</td>
                            <td>1/5</td>
                            <td>2,8/5</td>
                        </tr>
                        <tr style="background:#d1ecf1;">
                            <td>Musgrave</td>
                            <td>4/5</td>
                            <td>5/5</td>
                            <td>5/5</td>
                            <td>3/5</td>
                            <td>4/5</td>
                            <td>4,2/5</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- CONCLUSION -->
        <section id="conclusion" class="section">
            <h2>🏆 Chapitre 5 : Conclusion et recommandations</h2>

            <h3>5.1 Synthèse des résultats</h3>

            <div class="concept-box">
                <div class="concept-title">Réponse aux questions de recherche</div>
                <ul>
                    <li><strong>Q1 (Diagnostic) :</strong> Sans réforme, le système belge devient insolvable dès 2035 (RSV < 0,90) et atteint 0,72 en 2070.</li>
                    <li><strong>Q2 (Solutions) :</strong> Les MAA permettent de maintenir le RSV entre 0,98 et 1,05, garantissant ainsi la solvabilité.</li>
                    <li><strong>Q3 (Optimisation) :</strong> La règle de Musgrave offre le meilleur compromis (score 4,2/5), suivie par MAA 2 (4,0/5).</li>
                </ul>
            </div>

            <h3>5.2 Performance des mécanismes</h3>
            <div class="grid-3">
                <div class="info-box">
                    <div class="info-title">Plus efficace</div>
                    <p><strong>MAA 2</strong> (ajustement de l'âge) car il répond directement à la cause (longévité) et préserve la compétitivité économique.</p>
                </div>
                <div class="info-box">
                    <div class="info-title">Plus équitable</div>
                    <p><strong>Règle de Musgrave</strong> car elle partage le fardeau selon les capacités contributives.</p>
                </div>
                <div class="info-box">
                    <div class="info-title">Plus robuste</div>
                    <p><strong>Musgrave et MAA 2</strong> résistent mieux aux chocs démographiques et économiques.</p>
                </div>
            </div>

            <h3>5.3 Recommandations politiques pour la Belgique</h3>

            <div class="warning-box">
                <div class="warning-title">Recommandation 1 : Instaurer un MAA hybride</div>
                <p>Combiner <strong>l'ajustement de l'âge de retraite</strong> (MAA 2) avec un <strong>facteur de durabilité</strong> (MAA 5) pour les chocs économiques.</p>
                <p><strong>Calibrage :</strong></p>
                <ul>
                    <li>Âge de retraite : ajustement automatique de +0,3 an par an si e_{65} augmente</li>
                    <li>Facteur de durabilité : activation si RSV < 0,95 pendant 3 ans consécutifs</li>
                </ul>
            </div>

            <div class="warning-box">
                <div class="warning-title">Recommandation 2 : Créer une clause de sauvegarde</div>
                <p>Prévoir un <strong>mécanisme de correction automatique</strong> en cas de déviation majeure.</p>
                <div class="formula-container">
                    <div class="formula">
\text{Si } RSV_t < 0,90 \times RSV_{t-1} \text{ pendant 2 ans} \Rightarrow
\begin{cases}
c_t \leftarrow \min(c_t + 3\%, 25\%) \\
P_t \leftarrow P_t \times 0,95
\end{cases}
                    </div>
                </div>
            </div>

            <div class="warning-box">
                <div class="warning-title">Recommandation 3 : Limiter la détérioration des pensions</div>
                <p>Fixer un <strong>plancher de protection</strong> pour les pensions.</p>
                <ul>
                    <li><strong>Plancher :</strong> pension ≥ 50% du salaire moyen (revalorisation minimum)</li>
                    <li><strong>Plafond :</strong> cotisation ≤ 25% du salaire brut</li>
                    <li><strong>Dérogations :</strong> travaux pénibles, carrières longues</li>
                </ul>
            </div>

            <div class="warning-box">
                <div class="warning-title">Recommandation 4 : Renforcer la gouvernance</div>
                <p>Instituer une <strong>Commission indépendante des pensions</strong> chargée de :</p>
                <ul>
                    <li>Publier annuellement les projections détaillées</li>
                    <li>Évaluer la performance des MAA</li>
                    <li>Proposer des ajustements techniques (β, γ, etc.)</li>
                    <li>Communiquer auprès du public</li>
                </ul>
            </div>

            <h3>5.4 Limite de l'étude</h3>
            <ul>
                <li><strong>Simplification unisexe :</strong> les différences de mortalité hommes/femmes ne sont pas modélisées</li>
                <li><strong>Absence de second pilier :</strong> les effets de substitution avec les régimes de retraite complémentaires ne sont pas pris en compte</li>
                <li><strong>Hypothèses de plein emploi :</strong> le taux d'emploi des seniors est supposé constant</li>
                <li><strong>Comportements non modélisés :</strong> réactions des agents aux incitations (effets de substitution)</li>
            </ul>

            <h3>5.5 Perspectives de recherche</h3>
            <div class="grid-2">
                <div>
                    <h4>Extensions méthodologiques</h4>
                    <ul>
                        <li>Modèles de mortalité multi-populations (hommes/femmes, CSP)</li>
                        <li>Intégration des effets de cohorte (Renshaw & Haberman)</li>
                        <li>Modèles avec changement de régime (Markov switching)</li>
                    </ul>
                </div>
                <div>
                    <h4>Extensions politiques</h4>
                    <ul>
                        <li>Analyse des effets de redistribution intra-générationnelle</li>
                        <li>Étude de l'acceptabilité des MAA par enquêtes</li>
                        <li>Modélisation des effets de l'IA sur l'emploi des seniors</li>
                    </ul>
                </div>
            </div>

            <div class="concept-box">
                <div class="concept-title">Message final</div>
                <p>Les MAA ne sont pas une solution miracle mais un <strong>outil indispensable de gestion des risques démographiques</strong>. Ils permettent d'éviter les impasses politiques et d'assurer la viabilité du système pour les générations futures. Leur succès dépend de trois facteurs :</p>
                <ol>
                    <li><strong>Transparence</strong> : les formules doivent être claires et publiques</li>
                    <li><strong>Légitimité</strong> : le partage des ajustements doit être perçu comme équitable</li>
                    <li><strong>Flexibilité</strong> : des clauses de sauvegarde doivent exister pour les situations extrêmes</li>
                </ol>
            </div>
        </section>

        <!-- ANNEXES -->
        <section id="annexes" class="section">
            <h2>📎 Annexes détaillées</h2>

            <h3>Annexe 1 : Méthode ARIMA pour la projection des kt</h3>

            <div class="concept-box">
                <div class="concept-title">Principe des séries temporelles</div>
                <p>L'indice de mortalité k_t suit généralement une <strong>marche aléatoire avec drift</strong>. Le modèle ARIMA(p,d,q) permet de modéliser les autocorrélations.</p>
            </div>

            <h4>Identification du modèle</h4>
            <ul>
                <li><strong>ACF (Autocorrélation) :</strong> décroissance lente → d=1 (intégration)</li>
                <li><strong>PACF (Autocorrélation partielle) :</strong> coupure après lag 1 → MA(1)</li>
                <li><strong>Test ADF :</strong> p-value = 0,12 (unit root) → différenciation nécessaire</li>
            </ul>

            <div class="formula-group">
                <div class="formula-title">Modèle ARIMA(0,1,1) retenu</div>
                <div class="formula-container">
                    <div class="formula">
k_t = k_{t-1} - 0,85 + ε_t + 0,42 \times ε_{t-1}, \quad ε_t \sim N(0, 0,78^2)
                    </div>
                    <div class="formula-comment">
                        Drift μ = -0,85 (amélioration annuelle de la mortalité)<br>
                        MA(1) θ = 0,42 (effet persistant)<br>
                        σ = 0,78 (volatilité des résidus)
                    </div>
                </div>
            </div>

            <h4>Validation du modèle</h4>
            <div class="grid-2">
                <div class="formula-group">
                    <div class="formula-title">Test de Ljung-Box</div>
                    <div class="formula-container">
                        <div class="formula">Q(10) = 14,23, \quad p-value = 0,42</div>
                        <div class="formula-comment">Résidus non autocorrélés (hypothèse validée)</div>
                    </div>
                </div>
                <div class="formula-group">
                    <div class="formula-title">Test de normalité (Shapiro-Wilk)</div>
                    <div class="formula-container">
                        <div class="formula">W = 0,987, \quad p-value = 0,08</div>
                        <div class="formula-comment">Résidus normaux (non rejet de H0)</div>
                    </div>
                </div>
            </div>

            <h4>Code R pour les projections</h4>
            <div class="formula-container" style="font-family:'Courier New'; font-size:0.9em; line-height:1.4;">
                <div class="formula">
# ========================================
# Prolongement des kt avec ARIMA
# ========================================

library(forecast)
library(demography)

# Estimation Lee-Carter Poisson
belgium <- read.demogdata("belgium.txt", "belgium_exp.txt")
lc_fit <- lca(belgium, adjust = "dt", model = "poisson")

# Sélection ARIMA automatique
kt_ts <- ts(lc_fit$kt, start = 1981)
arima_model <- auto.arima(kt_ts, d = 1, max.p = 2, max.q = 2)

# Projection 100 ans
kt_forecast <- forecast(arima_model, h = 100, level = 95)

# Calcul intervalles de confiance
kt_lower <- kt_forecast$lower[,2]  # IC 95%
kt_upper <- kt_forecast$upper[,2]
                </div>
            </div>

            <h3>Annexe 2 : Simulations de population détaillées</h3>

            <h4>Hypothèses de base</h4>
            <div class="grid-2">
                <div class="formula-group">
                    <div class="formula-title">Poids des groupes d'âge en 2023</div>
                    <div class="formula-container">
