        }

        .formula-comment {
            color: #aaa;
            font-size: 0.95em;
            font-style: italic;
            margin-top: -10px;
            margin-bottom: 20px;
            padding: 15px 20px;
            background: rgba(0,0,0,0.2);
            border-radius: 0 0 8px 8px;
            line-height: 1.5;
        }

        .formula-inline {
            font-family: 'Courier New', monospace;
            background: #f4f4f4;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: 600;
            color: var(--accent);
        }

        /* TABLEAUX */
        .table-container {
            margin: 30px 0;
            overflow-x: auto;
            border-radius: 10px;
            box-shadow: var(--shadow);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9em;
        }

        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #dee2e6;
        }

        th {
            background: var(--primary);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85em;
            letter-spacing: 0.5px;
            position: sticky;
            top: 0;
        }

        tr:nth-child(even) {
            background: #f8f9fa;
        }

        tr:hover {
            background: #e3f2fd;
            transition: background 0.3s;
        }

        /* GRILLES */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin: 30px 0;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin: 30px 0;
        }

        /* LISTES */
        ul, ol {
            margin: 20px 0 20px 40px;
        }

        li {
            margin: 12px 0;
        }

        .list-unstyled {
            list-style: none;
            margin-left: 0;
        }

        /* BOUTONS */
        .btn-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--secondary);
            color: white;
            padding: 12px 18px;
            border-radius: 50%;
            text-decoration: none;
            box-shadow: var(--shadow);
            transition: all 0.3s;
            z-index: 1000;
        }

        .btn-top:hover {
            background: var(--primary);
            transform: translateY(-3px);
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .header {
                padding: 50px 30px;
            }

            .header h1 {
                font-size: 2.2em;
            }

            .section {
                padding: 30px;
            }

            .section h2 {
                font-size: 1.8em;
            }

            .nav-main {
                padding: 0 30px;
            }

            .nav-list {
                gap: 10px;
            }

            .nav-list a {
                font-size: 0.8em;
                padding: 6px 12px;
            }

            .grid-2 {
                grid-template-columns: 1fr;
            }

            .formula {
                font-size: 0.9em;
                padding: 15px;
            }
        }

        @media print {
            body {
                background: white;
            }

            .nav-container {
                display: none;
            }

            .container {
                box-shadow: none;
            }

            .header {
                background: white !important;
                color: black !important;
            }

            .header .meta {
                border-top: 1px solid black;
            }

            .formula-container {
                background: white;
                color: black;
                border: 1px solid black;
            }

            .formula {
                background: #f0f0f0;
                color: black;
            }

            .btn-top {
                display: none;
